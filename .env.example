# Configuración de la aplicación Mini POS

# Modo de la aplicación: development o production
FLASK_ENV=development

# Clave secreta para sesiones (cambiar en producción)
SECRET_KEY=tu-clave-secreta-super-segura-aqui

# Configuración de la base de datos MySQL
# Formato: mysql+pymysql://usuario:contraseña@host:puerto/base_datos
DATABASE_URL=mysql+pymysql://root:@localhost:3306/pos_inventario
